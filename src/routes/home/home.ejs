<%- include('../partials/header') %>

  <!-- Hero -->
  <div class="hero">
    <div class="hero-logo">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"/>
        <line x1="12" y1="2" x2="12" y2="22"/>
        <path d="M2 8.5h20"/>
      </svg>
    </div>
    <h1>Lux Anima Studio</h1>
    <p class="hero-sub">Tableau de bord — administration & analytics</p>
  </div>

  <!-- Stats -->
  <div class="stats">
    <div class="stat-card">
      <span class="stat-card-num"><%= totalVisits.toLocaleString('fr-FR') %></span>
      <span class="stat-card-label">Visites totales</span>
      <span class="stat-card-delta">+<%= recentVisits %> dernières 24h</span>
    </div>
    <div class="stat-card">
      <span class="stat-card-num"><%= totalEvents.toLocaleString('fr-FR') %></span>
      <span class="stat-card-label">Events analytics</span>
      <span class="stat-card-delta">+<%= recentEvents %> dernières 24h</span>
    </div>
    <div class="stat-card">
      <span class="stat-card-num"><%= totalSaves.toLocaleString('fr-FR') %></span>
      <span class="stat-card-label">Cloud saves</span>
    </div>
    <div class="stat-card">
      <span class="stat-card-num"><%= totalPlayers.toLocaleString('fr-FR') %></span>
      <span class="stat-card-label">Joueurs</span>
    </div>
    <div class="stat-card uptime">
      <span class="stat-card-num"><span class="stat-dot"></span><%= uptime %></span>
      <span class="stat-card-label">Uptime serveur</span>
    </div>
  </div>

  <!-- Navigation -->
  <div class="section-label">Navigation</div>
  <div class="nav-grid">

    <a href="/dashboard/visits" class="nav-card">
      <div class="nav-card-icon blue">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="20" x2="18" y2="10"/>
          <line x1="12" y1="20" x2="12" y2="4"/>
          <line x1="6"  y1="20" x2="6"  y2="14"/>
        </svg>
      </div>
      <div class="nav-card-body">
        <p class="nav-card-title">Statistiques de visites</p>
        <p class="nav-card-desc">Trafic mensuel par année avec graphiques en barres</p>
        <p class="nav-card-url">/dashboard/visits</p>
      </div>
    </a>

    <a href="/dashboard/analytics" class="nav-card">
      <div class="nav-card-icon teal">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
        </svg>
      </div>
      <div class="nav-card-body">
        <p class="nav-card-title">Analytics jeux & sites</p>
        <p class="nav-card-desc">Suivi d'événements — actions, pays, plateformes, sessions</p>
        <p class="nav-card-url">/dashboard/analytics</p>
      </div>
    </a>

    <a href="/dashboard/saves" class="nav-card">
      <div class="nav-card-icon green">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
          <polyline points="17 21 17 13 7 13 7 21"/>
          <polyline points="7 3 7 8 15 8"/>
        </svg>
      </div>
      <div class="nav-card-body">
        <p class="nav-card-title">Cloud Saves</p>
        <p class="nav-card-desc">Gestion des sauvegardes joueurs, versions et slots par jeu</p>
        <p class="nav-card-url">/dashboard/saves</p>
      </div>
    </a>

    <a href="/health" class="nav-card">
      <div class="nav-card-icon green">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
      </div>
      <div class="nav-card-body">
        <p class="nav-card-title">Health check</p>
        <p class="nav-card-desc">Statut du serveur, uptime et environnement en JSON</p>
        <p class="nav-card-url">/health</p>
      </div>
    </a>

    <div class="nav-card" style="opacity: 0.45; cursor: default;">
      <div class="nav-card-icon amber">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3"/>
          <path d="M19.07 4.93A10 10 0 1 0 4.93 19.07"/>
          <path d="M19.07 4.93L4.93 19.07"/>
        </svg>
      </div>
      <div class="nav-card-body">
        <p class="nav-card-title">API — POST /analytics/event</p>
        <p class="nav-card-desc">Envoyer un événement depuis un jeu ou un site. Requiert <code style="font-size:0.7rem; color:#f59e0b;">x-api-key</code></p>
        <p class="nav-card-url">/analytics/event</p>
      </div>
    </div>

    <div class="nav-card" style="opacity: 0.45; cursor: default;">
      <div class="nav-card-icon amber">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
          <polyline points="10 9 9 9 8 9"/>
        </svg>
      </div>
      <div class="nav-card-body">
        <p class="nav-card-title">API — GET /analytics/stats</p>
        <p class="nav-card-desc">Stats agrégées filtrables par source, action, dates. Requiert <code style="font-size:0.7rem; color:#f59e0b;">x-api-key</code></p>
        <p class="nav-card-url">/analytics/stats</p>
      </div>
    </div>

  </div>

<%- include('../partials/footer') %>
