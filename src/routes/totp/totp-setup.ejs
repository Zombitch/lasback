<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Configuration TOTP — Lux Anima Studio</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="centered">

  <div class="card">
    <div class="card-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
    </div>

    <h1>Configuration TOTP</h1>
    <p class="subtitle">
      Scannez le QR code ci-dessous avec votre application d'authentification
      (Google Authenticator, Authy, etc.) puis entrez le code pour activer la protection.
    </p>

    <div class="qr-wrapper">
      <img src="<%= qrDataUrl %>" alt="QR Code TOTP" />
    </div>

    <div class="secret-label">Clé secrète (saisie manuelle)</div>
    <div class="secret-box"><%= secret %></div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <form method="POST" action="/totp/setup" autocomplete="off">
      <label for="code">Code de vérification</label>
      <input
        type="text"
        id="code"
        name="code"
        placeholder="000000"
        maxlength="6"
        pattern="[0-9]{6}"
        inputmode="numeric"
        required
        autofocus
      />
      <button type="submit">Activer le TOTP</button>
    </form>
  </div>

</body>
</html>
